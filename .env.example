# --- Google Sheets backend ---
# The spreadsheet ID from the URL (the long string between /d/ and /edit)
GOOGLE_SHEET_ID=

# Service account credentials (download JSON key from Google Cloud Console)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste private key with literal \n for newlines (or wrap in real newlines if your host supports it)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Auth ---
# Shared password for the friend group
APP_PASSWORD=change-me
# Random string used to sign the session cookie
SESSION_SECRET=replace-with-random-bytes
