# --- Supabase backend ---
# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co  (Project settings → API)
SUPABASE_URL=
# Service-role key (Project settings → API → service_role). Server-side only —
# never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth ---
# Shared password for the friend group
APP_PASSWORD=change-me
# Random string used to sign the session cookie
SESSION_SECRET=replace-with-random-bytes

# --- Legacy (Google Sheets) ---
# Only needed to run the one-time `npm run migrate-to-supabase` script, which
# reads the old spreadsheet. Safe to remove once the migration is done.
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
