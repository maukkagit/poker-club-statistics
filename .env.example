# --- Supabase backend ---
# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co  (Project settings → API)
SUPABASE_URL=
# Service-role key (Project settings → API → service_role). Server-side only —
# never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Tournament clock realtime (OPTIONAL) ---
# Used only by the public clock viewer (/clock/{token}) to receive instant
# updates over Supabase Realtime broadcast. When unset, viewers fall back to
# polling (a few seconds of lag). These are the PUBLIC project URL + anon
# (publishable) key — safe to ship to the browser. The anon key is at
# Project settings → API → anon/public.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Auth ---
# Shared password for the friend group
APP_PASSWORD=change-me
# Random string used to sign the session cookie
SESSION_SECRET=replace-with-random-bytes
